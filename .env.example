# ClearSign environment configuration
# ----------------------------------------------------------------------------
# IMPORTANT: secrets live ONLY on the backend (api/). The browser bundle no
# longer embeds any LLM provider key. Set these in your Functions app settings
# (or local api/local.settings.json), NOT in the Vite build.
# ----------------------------------------------------------------------------

# --- Backend (api/) secrets ---

# ANTHROPIC_API_KEY: Claude API key used by the analyze/ask/ocr endpoints.
ANTHROPIC_API_KEY="sk-ant-..."

# STRIPE_SECRET_KEY: Stripe secret key for creating Checkout sessions.
STRIPE_SECRET_KEY="sk_test_..."

# STRIPE_WEBHOOK_SECRET: Signing secret for verifying Stripe webhooks.
STRIPE_WEBHOOK_SECRET="whsec_..."

# AZURE_STORAGE_CONNECTION_STRING: Table Storage connection for the credit ledger.
# Use "UseDevelopmentStorage=true" with Azurite for local development.
AZURE_STORAGE_CONNECTION_STRING="UseDevelopmentStorage=true"

# --- Frontend (build-time, safe to expose) ---

# VITE_API_BASE_URL: Base URL for the backend functions. Leave blank to use the
# same origin (recommended for Static Web Apps where /api is co-hosted).
VITE_API_BASE_URL=""
